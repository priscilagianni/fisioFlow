{
  "info": {
    "name": "FisioFlow API",
    "description": "Coleção completa para testar a API FisioFlow — pacientes, agendamentos e utilitários.\n\n**Como usar:**\n1. Importe esta coleção no Postman\n2. Certifique-se que o servidor está rodando em http://localhost:3000\n3. Execute as requisições na ordem sugerida (Utilitário → Pacientes → Agendamentos)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "2.0.0"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "patientId", "value": "1", "type": "string" },
    { "key": "appointmentId", "value": "1", "type": "string" },
    { "key": "tomorrow", "value": "2025-12-20", "type": "string", "description": "Altere para uma data futura válida" }
  ],
  "item": [

    {
      "name": "🔧 Utilitário",
      "item": [
        {
          "name": "Resetar banco de dados",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/test/reset",
            "description": "Remove todos os dados em memória e reinicia os IDs. Use antes de cada sequência de testes."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Mensagem de sucesso', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.message).to.include('sucesso');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "👤 Pacientes",
      "item": [

        {
          "name": "Criar paciente (campos obrigatórios)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/patients",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Maria Souza\",\n  \"age\": 42\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('ID gerado', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.be.a('number');",
                  "  pm.collectionVariables.set('patientId', json.id);",
                  "});",
                  "pm.test('Nome correto', () => {",
                  "  pm.expect(pm.response.json().name).to.equal('Maria Souza');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Criar paciente (campos completos)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/patients",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Silva\",\n  \"age\": 35,\n  \"phone\": \"(81) 99999-0001\",\n  \"diagnosis\": \"Lombalgia crônica\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Diagnosis presente', () => {",
                  "  pm.expect(pm.response.json().diagnosis).to.equal('Lombalgia crônica');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "[Erro] Criar paciente sem nome",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/patients",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"age\": 30\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Mensagem de erro', () => {",
                  "  pm.expect(pm.response.json().error).to.include('Nome');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "[Erro] Criar paciente com nome inválido (números)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/patients",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Maria123\",\n  \"age\": 30\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Erro de validação', () => {",
                  "  pm.expect(pm.response.json().error).to.include('letras');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "[Erro] Criar paciente com idade inválida (0)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/patients",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ana Lima\",\n  \"age\": 0\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Erro de faixa etária', () => {",
                  "  pm.expect(pm.response.json().error).to.include('1 e 120');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Listar pacientes",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/patients"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna array', () => {",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Buscar paciente por ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/patients/{{patientId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('ID correto', () => {",
                  "  pm.expect(pm.response.json().id).to.equal(Number(pm.collectionVariables.get('patientId')));",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "[Erro] Buscar paciente inexistente",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/patients/9999"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        },

        {
          "name": "Atualizar paciente",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/patients/{{patientId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"(81) 98765-4321\",\n  \"diagnosis\": \"Lombalgia crônica e hérnia de disco L4-L5\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Telefone atualizado', () => {",
                  "  pm.expect(pm.response.json().phone).to.equal('(81) 98765-4321');",
                  "});",
                  "pm.test('updatedAt presente', () => {",
                  "  pm.expect(pm.response.json().updatedAt).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Excluir paciente",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/patients/{{patientId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Mensagem de sucesso', () => {",
                  "  pm.expect(pm.response.json().message).to.include('sucesso');",
                  "});"
                ]
              }
            }
          ]
        }

      ]
    },

    {
      "name": "📅 Agendamentos",
      "item": [

        {
          "name": "Criar agendamento válido",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/appointments",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"date\": \"{{tomorrow}}\",\n  \"time\": \"09:00\",\n  \"durationMinutes\": 50,\n  \"type\": \"Fisioterapia Ortopédica\",\n  \"notes\": \"Dor no joelho esquerdo\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('ID gerado', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.be.a('number');",
                  "  pm.collectionVariables.set('appointmentId', json.id);",
                  "});",
                  "pm.test('patientName preenchido', () => {",
                  "  pm.expect(pm.response.json().patientName).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "[Erro] Conflito de horário",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/appointments",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"date\": \"{{tomorrow}}\",\n  \"time\": \"09:20\",\n  \"durationMinutes\": 50,\n  \"type\": \"Retorno\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409', () => pm.response.to.have.status(409));",
                  "pm.test('Mensagem de conflito', () => {",
                  "  pm.expect(pm.response.json().error).to.include('Conflito');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "[Erro] Data passada",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/appointments",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"date\": \"2020-01-01\",\n  \"time\": \"09:00\",\n  \"durationMinutes\": 50,\n  \"type\": \"Retorno\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Erro de data passada', () => {",
                  "  pm.expect(pm.response.json().error).to.include('passadas');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "[Erro] Paciente inexistente",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/appointments",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": 9999,\n  \"date\": \"{{tomorrow}}\",\n  \"time\": \"14:00\",\n  \"durationMinutes\": 50,\n  \"type\": \"Retorno\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Paciente não encontrado', () => {",
                  "  pm.expect(pm.response.json().error).to.include('Paciente não encontrado');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Listar agendamentos",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/appointments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna array', () => {",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Agendamentos por dia",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/appointments/day/{{tomorrow}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna array do dia', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.be.an('array');",
                  "  json.forEach(a => pm.expect(a.date).to.equal(pm.collectionVariables.get('tomorrow')));",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Atualizar agendamento",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/appointments/{{appointmentId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"Pilates Clínico\",\n  \"notes\": \"Paciente evoluindo bem\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tipo atualizado', () => {",
                  "  pm.expect(pm.response.json().type).to.equal('Pilates Clínico');",
                  "});",
                  "pm.test('updatedAt presente', () => {",
                  "  pm.expect(pm.response.json().updatedAt).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Excluir agendamento",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/appointments/{{appointmentId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Mensagem de sucesso', () => {",
                  "  pm.expect(pm.response.json().message).to.include('sucesso');",
                  "});"
                ]
              }
            }
          ]
        }

      ]
    }

  ]
}